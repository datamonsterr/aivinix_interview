{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "aivinix-interview",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "dev": "next dev -p 8080",
    "build": "next build",
    "start": "next start -p 8080",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "bench:cache-hit": "vitest run tests/unit/cache-hit-benchmark.test.ts"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.55.0",
    "@types/node": "24.7.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitest/coverage-istanbul": "4.0.7",
    "eslint": "9.38.0",
    "eslint-config-next": "16.1.6",
    "typescript": "5.9.3",
    "vitest": "4.1.6"
  }
}
